# Скопируйте этот файл в .env.prod.local и заполните реальными значениями.
# .env.prod.local НЕ добавляется в git (уже в .gitignore).
#
# Сгенерировать APP_SECRET:
#   php -r "echo bin2hex(random_bytes(16));"

APP_SECRET=СГЕНЕРИРУЙТЕ_СЛУЧАЙНУЮ_СТРОКУ_32_СИМВОЛА

###> Doctrine ###
DATABASE_URL="postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_DATABASE}?serverVersion=17&charset=utf8"
###< Doctrine ###

###> Telegram ###
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_SECRET_HERE
###< Telegram ###

###> Ollama ###
OLLAMA_URL=http://ollama:11434
###< Ollama ###
