# Скопируйте этот файл в .env.local:
#   cp app/.env.local.example app/.env.local
#
# .env.local НЕ добавляется в git.
# Переменные DB_* берутся из root/.env через docker-compose.yml и
# инжектируются в PHP-контейнер как переменные окружения.
###> Doctrine ###
DATABASE_URL="mysql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:3306/${DB_DATABASE}?serverVersion=mariadb-11.3.0&charset=utf8mb4"
