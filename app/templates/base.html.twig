<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Блог{% endblock %}</title>
    {% block stylesheets %}{% endblock %}
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }

        nav {
            background: #1a1a2e;
            padding: 0 2rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            height: 56px;
            box-shadow: 0 2px 6px rgba(0,0,0,.3);
        }
        nav a {
            color: #e0e0e0;
            text-decoration: none;
            font-size: .95rem;
            transition: color .2s;
        }
        nav a:first-child { font-weight: 700; font-size: 1.1rem; color: #fff; margin-right: auto; }
        nav a:hover { color: #7eb3ff; }

        .container {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        h1 { font-size: 2rem; margin-bottom: 1.5rem; color: #1a1a2e; }
        h2 { font-size: 1.25rem; margin-bottom: .5rem; }
        h2 a { color: #1a1a2e; text-decoration: none; }
        h2 a:hover { color: #4a7fd4; }

        article { background: #fff; border-radius: 8px; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        article p { color: #555; margin-top: .5rem; }
        article p.meta { font-size: .85rem; color: #888; margin-top: .75rem; }
        article p.meta a { color: #4a7fd4; text-decoration: none; }

        hr { border: none; border-top: 1px solid #e0e0e0; margin: 1rem 0; }

        /* Forms */
        form label { display: block; margin-bottom: .3rem; font-weight: 600; font-size: .9rem; }
        form input[type="text"],
        form input[type="email"],
        form input[type="password"],
        form textarea,
        form select {
            width: 100%; padding: .55rem .75rem;
            border: 1px solid #ccc; border-radius: 6px;
            font-size: 1rem; margin-bottom: 1rem;
            transition: border-color .2s;
        }
        form input:focus, form textarea:focus, form select:focus {
            outline: none; border-color: #4a7fd4;
        }
        button[type="submit"], .btn {
            background: #4a7fd4; color: #fff; border: none;
            padding: .55rem 1.4rem; border-radius: 6px;
            font-size: 1rem; cursor: pointer; transition: background .2s;
            text-decoration: none; display: inline-block;
        }
        button[type="submit"]:hover, .btn:hover { background: #3568c0; }
        .btn-danger { background: #e05252; }
        .btn-danger:hover { background: #c43a3a; }
        .btn-secondary { background: #888; }
        .btn-secondary:hover { background: #666; }

        /* Table */
        table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        th { background: #1a1a2e; color: #fff; padding: .75rem 1rem; text-align: left; font-size: .9rem; }
        td { padding: .7rem 1rem; border-bottom: 1px solid #f0f0f0; font-size: .95rem; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: #f9f9ff; }

        .actions { display: flex; gap: .5rem; align-items: center; }
        .actions form { margin: 0; }
        .actions button { padding: .35rem .9rem; font-size: .85rem; }
        .badge-yes { color: #2a9d2a; font-weight: 600; }
        .badge-no  { color: #999; }

        .card { background: #fff; border-radius: 8px; padding: 2rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); }

        .alert { padding: .75rem 1rem; border-radius: 6px; margin-bottom: 1rem; font-size: .95rem; }
        .alert-error { background: #fde8e8; color: #c0392b; border: 1px solid #f5c6c6; }
        .alert-success { background: #e8f8e8; color: #256325; border: 1px solid #b8e6b8; }
    </style>
</head>
<body>
    <nav>
        <a href="{{ path('blog_index') }}">📰 Блог</a>
        {% if app.user %}
            <a href="{{ path('admin_post_index') }}">Админка</a>
            <a href="{{ path('app_logout') }}">Выйти ({{ app.user.userIdentifier }})</a>
        {% else %}
            <a href="{{ path('app_login') }}">Вход</a>
            <a href="{{ path('app_register') }}">Регистрация</a>
        {% endif %}
    </nav>

    <div class="container">
        {% block body %}{% endblock %}
    </div>

    {% block javascripts %}{% endblock %}
</body>
</html>
