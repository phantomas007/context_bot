APP_ENV=prod
APP_DEBUG=0

NGINX_SERVER_NAME=localhost

POSTGRES_DB=blog
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=secret_password_blog

RABBITMQ_USER=rabbitmq_user
RABBITMQ_PASSWORD=secret_password_rabbit
RABBITMQ_VHOST=/

DB_HOST=db
DB_DATABASE=${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST:-rabbitmq}:5672${RABBITMQ_VHOST:-/}
